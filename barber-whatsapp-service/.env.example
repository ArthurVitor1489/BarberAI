# Banco de Dados PostgreSQL (Exemplo padrão)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barber_db?schema=public"

# Configurações do Servidor NestJS
PORT=3000

# Configurações da OpenAI
OPENAI_API_KEY="sua_chave_api_openai_aqui"

# Configurações da Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua_chave_api_evolution_aqui"
EVOLUTION_INSTANCE_NAME="sua_instancia_whatsapp"
